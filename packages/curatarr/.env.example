# Curatarr configuration
# Copy this file to .env and fill in your values.
# Settings here are loaded on every server start and override the DB.
# Inside Docker, the container environment variables take priority — set them
# in docker-compose.yml or via Docker secrets instead of this file.

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# Server-side URL used by Curatarr's backend to reach Jellyfin.
# NOT your browser URL — this is used by the Node.js process.
#
#   Bare-metal / local dev:  http://localhost:8096
#   Docker (same compose):   http://jellyfin:8096   (service hostname)
#   Docker Desktop (mac):    http://host.docker.internal:8096
JELLYFIN_URL=http://localhost:8096

# API key from Jellyfin Dashboard → Administration → API Keys → New key
JELLYFIN_API_KEY=

# ── Library ───────────────────────────────────────────────────────────────────
# Absolute path to your movies folder (as seen by the Curatarr process).
# In Docker this is the container path of the mounted volume (e.g. /media).
LIBRARY_PATH=/media/Movies

# ── LLM Provider (optional) ──────────────────────────────────────────────────
# One of: openai, anthropic, ollama, openrouter
LLM_PROVIDER=

# API key for the chosen LLM provider (not needed for Ollama)
LLM_API_KEY=
