{
  "name": "curatarr",
  "version": "0.2.0",
  "description": "LLM-backed intelligent media library management",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/server/dist/index.js",
  "bin": {
    "curatarr": "src/server/dist/index.js"
  },
  "scripts": {
    "build:ui": "cd src/ui && npm run build",
    "docs:api:build": "node scripts/build-openapi-docs.mjs",
    "docs:api:validate": "node scripts/build-openapi-docs.mjs --validate-only",
    "build": "npm run build:ui && tsc -p .",
    "build:server": "tsc -p .",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "check": "biome check .",
    "format": "biome format . --write",
    "typecheck": "npm run typecheck:server && npm run typecheck:ui",
    "typecheck:server": "tsc -p . --noEmit",
    "typecheck:ui": "cd src/ui && tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "clean": "rm -rf dist dist-ui src/dist-ui src/server/dist src/ui/dist",
    "dev": "concurrently -n tsc,api,ui -c cyan,magenta,yellow \"tsc -w --preserveWatchOutput\" \"node --watch src/server/dist/index.js serve\" \"cd src/ui && npm run dev\"",
    "dev:server": "concurrently -n tsc,api -c cyan,magenta \"tsc -w --preserveWatchOutput\" \"node --watch src/server/dist/index.js serve\"",
    "dev:ui": "cd src/ui && npm run dev",
    "serve": "node src/server/dist/index.js serve"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "hono": "^4.12.3",
    "openai": "^4.28.0",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "typescript": "^5.4.5"
  }
}
